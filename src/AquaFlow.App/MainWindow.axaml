<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AquaFlow.App.Views"
        x:Class="AquaFlow.App.MainWindow"
        Title="AquaFlow"
        Width="1080" Height="780">
    <!-- Три вкладки из ТЗ (раздел 8). Метрики и История появятся в M6. -->
    <TabControl>
        <TabItem Header="Симуляция">
            <views:SimulationView x:Name="SimulationTab" />
        </TabItem>
        <TabItem Header="Метрики">
            <TextBlock Margin="20" Text="Здесь появится дашборд accuracy и матрицы ошибок (M6)." />
        </TabItem>
        <TabItem Header="История">
            <TextBlock Margin="20" Text="Здесь появится таблица прошлых прогонов (M6)." />
        </TabItem>
    </TabControl>
</Window>
