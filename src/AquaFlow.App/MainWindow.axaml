<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AquaFlow.App.Views"
        x:Class="AquaFlow.App.MainWindow"
        Title="AquaFlow"
        Width="1080" Height="780">
    <!-- Три вкладки из ТЗ (раздел 8). -->
    <TabControl>
        <TabItem Header="Симуляция">
            <views:SimulationView x:Name="SimulationTab" />
        </TabItem>
        <TabItem Header="Метрики">
            <views:MetricsView x:Name="MetricsTab" />
        </TabItem>
        <TabItem Header="История">
            <views:HistoryView x:Name="HistoryTab" />
        </TabItem>
    </TabControl>
</Window>
