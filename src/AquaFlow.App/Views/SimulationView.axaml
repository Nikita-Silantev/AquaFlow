<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AquaFlow.App.Views.SimulationView">
    <Grid RowDefinitions="*,Auto" Margin="16">
        <ScrollViewer Grid.Row="0">
            <Canvas x:Name="NetworkCanvas" Width="980" Height="600" Background="Transparent" />
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,12,0,0" VerticalAlignment="Center">
            <Button x:Name="RunRealButton" Content="Реальный прогон" Click="OnRunRealClick" Padding="14,8" />
            <TextBlock x:Name="ResultText"
                       VerticalAlignment="Center"
                       Text="Выберите вход и клапаны, затем нажмите «Реальный прогон»." />
        </StackPanel>
    </Grid>
</UserControl>
